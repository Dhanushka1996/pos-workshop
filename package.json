{
  "name": "pos-workshop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "node scripts/start.js",
    "start:no-backup": "node scripts/start.js --no-backup",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:skip": "prisma db push --skip-generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts",
    "backup": "node scripts/backup.js",
    "backup:list": "node scripts/backup.js --list",
    "update:check": "node -e \"require('./scripts/backup.js'); console.log('Backup utility loaded.')\"",
    "release:bump-patch": "node -e \"const f='version.json',v=require('./'+f);const [a,b,c]=v.version.split('.').map(Number);v.version=a+'.'+b+'.'+(c+1);v.buildDate=new Date().toISOString().slice(0,10);require('fs').writeFileSync(f,JSON.stringify(v,null,2)+'\\n');console.log('Bumped to '+v.version);\"",
    "release:bump-minor": "node -e \"const f='version.json',v=require('./'+f);const [a,b]=v.version.split('.').map(Number);v.version=a+'.'+(b+1)+'.0';v.buildDate=new Date().toISOString().slice(0,10);require('fs').writeFileSync(f,JSON.stringify(v,null,2)+'\\n');console.log('Bumped to '+v.version);\""
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.4.0",
    "@prisma/client": "^5.13.0",
    "@tanstack/react-query": "^5.32.0",
    "@tanstack/react-query-devtools": "^5.32.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.1.7",
    "lucide-react": "^0.372.0",
    "next": "14.2.3",
    "next-auth": "^4.24.7",
    "next-themes": "^0.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.3",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "^8.4.38",
    "prisma": "^5.13.0",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
